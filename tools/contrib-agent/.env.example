# Copy to .env and fill in. .env is gitignored.

# --- Bedrock auth (us-east-2 cross-region inference) ---
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-2
AWS_BEARER_TOKEN_BEDROCK=

# Model the Agent SDK uses for Sonnet-tier work.
# Drop the [1m] suffix unless 200k context is insufficient.
ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Agent budgets ---
# Per-repo cap on output tokens before canUseTool denies further work.
SYNTHESIZE_TOKEN_BUDGET=50000
# Max conversation turns per repo.
SYNTHESIZE_MAX_TURNS=30
# Set to 1 to log every SDK message + every tool decision (very useful for tuning).
CONTRIB_AGENT_VERBOSE=1
# Set to 1 to skip the smoke-test step in validate (Phase 0).
CONTRIB_AGENT_SKIP_SMOKE=1
